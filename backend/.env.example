# Copy this file to .env and fill in your values

# --- Gemini (required for AI parsing) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- WhatsApp Cloud API (leave empty for local console-mode testing) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=finvox-verify-2026

# --- Database ---
# Local dev (default): SQLite file created automatically
DATABASE_URL=sqlite:///./finvox.db
# Production (Supabase): get this from Supabase > Project Settings > Database > Connection string (URI)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Dev mode: enables POST /dev/simulate so you can test without WhatsApp ---
DEV_MODE=true

# --- Admin token to view /api/admin/feedback. Use a long random string in production. ---
ADMIN_TOKEN=change-me-in-production
